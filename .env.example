# EmailJS (https://www.emailjs.com/) — free tier is enough for lead capture.
# Create a service + template, then paste the IDs below. The public key is safe to ship.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Admin login. Bcrypt hashes contain `$` characters which dotenv treats as
# variable expansion locally — always wrap the hash in SINGLE QUOTES here.
# (In Vercel's env-var UI, paste the hash as-is — no quotes needed.)
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD_HASH=''

# Server-side mirror of the same hash. Required for admin writes to succeed.
# Set this in Vercel to the SAME value as VITE_ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD_HASH=''

# Upstash Redis — provisioned via Vercel's Upstash integration.
# Vercel injects these automatically when you connect the database to the project.
# You do NOT set these manually in Vercel's env-var UI.
# Locally they're optional; if missing, admin writes go to .kv-local/ instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
